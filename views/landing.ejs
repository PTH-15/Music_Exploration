                <h1>Find your next favorite<br>sound, <span>off the algorithm.</span></h1>
                <p class="hero-sub">Dig into artists, albums, genres and curated playlists — plus the
                    stories behind the music you love.</p>

                <div class="hero-cta">
                    <a href="explore-artists" class="btn-solid btn-lg">Explore Artists <span class="arrow">→</span></a>
                    <a href="" class="btn-outline btn-lg">Browse Genres</a>
                </div>

                <div class="hero-stats">
                    <div class="stat">
                        <span class="stat-icon">🎧</span>
                        <div><strong>10,000+</strong><small>Artists</small></div>
                    </div>
                    <div class="stat">
                        <span class="stat-icon">🎵</span>
                        <div><strong>50+</strong><small>Genres</small></div>
                    </div>
                    <div class="stat">
                        <span class="stat-icon">📻</span>
                        <div><strong>100+</strong><small>Playlists</small></div>
                    </div>
                </div>
            </section>

            <div class="content">

                <section class="section-block search-section">
                    <div class="section-head">
                        <h2>Search Music Exploration</h2>
                    </div>
                    <div class="search-panel">
                        <div class="search-panel-field">
                            <svg class="search-icon" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            <input class="input" id="pageSearchInput" name="text" placeholder="Search artists, albums, songs or playlists..." type="search">
                        </div>
                        <div class="search-chips">
                            <button class="chip is-active" data-filter="all">All</button>
                            <button class="chip" data-filter="artists">Artists</button>
                            <button class="chip" data-filter="albums">Albums</button>
                            <button class="chip" data-filter="songs">Songs</button>
                            <button class="chip" data-filter="playlists">Playlists</button>
                        </div>
                    </div>
                </section>

                <section class="section-block">
                    <div class="section-head">
                        <h2>Featured Artists</h2>
                        <a href="artist" class="view-all">View All →</a>
                    </div>
                    <div class="carousel-wrap">
                        <div class="carousel" id="artistCarousel">
                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#3a2a1e,#12100e)">
