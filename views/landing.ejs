                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#242020,#0d0b0b)">
                                <span class="artist-name">Bhaskar</span>
                                <span class="artist-meta">35 Albums · 120 Songs</span>
                            </a>
                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#242020,#0d0b0b)">
                                <span class="artist-name">Rafatar</span>
                                <span class="artist-meta">35 Albums · 120 Songs</span>
