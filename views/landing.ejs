                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#241d2e,#0e0c12)">
                                <span class="artist-name">Raga</span>
                                <span class="artist-meta">25 Albums · 64 Songs</span>
                            </a>
                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#2c1720,#100a0d)">
                                <span class="artist-name">Karma</span>
                                <span class="artist-meta">60 Albums · 250 Songs</span>
                            </a>
                            <a href="" class="artist-card" style="--img: linear-gradient(160deg,#1e2622,#0b0f0d)">
