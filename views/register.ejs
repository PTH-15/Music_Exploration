<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Music Exploration</title>
    <link rel="stylesheet" href="/landing.css">
    <link rel="stylesheet" href="/register.css">
</head>

<body>
    <div class="container">
        <nav class="navbar">
            <div class="logo">Music<span>Exploration</span></div>

            <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>

            <div class="nav-links" id="navLinks">
                <a href="/">Home</a>
                <a href="/explore-artists">Explore</a>
                <a href="/views/">Playlists</a>
                <a href="">Genres</a>
                <a href="/artist">Artist</a>
                <a href="">About</a>
            </div>

            <div class="nav-search">
                <input class="input" id="searchInput" name="text" placeholder="Search artists, genres, playlists..." type="search">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>

            <div class="nav-auth">
                <a href="/login" class="btn-ghost">Log in</a>
                <a href="/register" class="btn-solid active">Sign up</a>
            </div>
        </nav>

        <main class="auth-page">
            <div class="auth-card">
                <div class="auth-header">
                    <h1>Create your account</h1>
                    <p>Start discovering artists and playlists</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-banner">
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form id="registerForm" class="auth-form" action="/api/auth/register" method="POST" novalidate>
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            placeholder="Choose a username"
                            required
                        />
                        <span class="field-error" id="usernameError"></span>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="you@example.com"
                            required
                        />
                        <span class="field-error" id="emailError"></span>
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <div class="password-wrapper">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                placeholder="Create a password"
                                required
                            />
                            <button type="button" class="toggle-password" id="togglePassword" aria-label="Show password">
                                👁
                            </button>
                        </div>
                        <span class="field-error" id="passwordError"></span>
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar" id="strengthBar"></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <div class="password-wrapper">
                            <input
                                type="password"
                                id="confirmPassword"
                                name="confirmPassword"
                                placeholder="Re-enter your password"
                                required
                            />
                            <button type="button" class="toggle-password" id="toggleConfirmPassword" aria-label="Show password">
                                👁
                            </button>
                        </div>
                        <span class="field-error" id="confirmPasswordError"></span>
                    </div>

                    <label class="terms-check">
                        <input type="checkbox" name="agreeTerms" id="agreeTerms" />
                        I agree to the <a href="/terms" target="_blank">Terms</a> and <a href="/privacy" target="_blank">Privacy Policy</a>
                    </label>
                    <span class="field-error" id="termsError"></span>

                    <button type="submit" class="auth-submit-btn" id="registerSubmitBtn">
                        Create Account
                    </button>
                </form>

                <div class="auth-switch-prompt">
                    Already have an account? <a href="/login">Log in</a>
                </div>
            </div>
        </main>

        <footer class="footer">
            <div class="footer-section">
                <h4>Music<span>Exploration</span></h4>
                <p>Your gateway to discover music. Find artists, genres and playlists beyond the algorithm.</p>
            </div>

            <div class="footer-section">
                <h4>Developer</h4>
                <a href="" class="links">Github</a>
                <a href="" class="links">LinkedIn</a>
            </div>
            <div class="footer-section">
                <h4>Resources</h4>
                <a href="" class="links">About</a>
                <a href="" class="links">Contact</a>
                <a href="" class="links">Privacy Policy</a>
            </div>
        </footer>
        <hr>
        <div class="footer-credit">
            © 2026 Music Exploration • Built by Prathmesh (PTH)
        </div>
    </div>

    <script src="/landing.js"></script>
    <script src="/register.js"></script>
</body>

</html>
